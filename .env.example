# Copia este archivo a .env y ajusta si cambias puertos o dominio.
#   cp .env.example .env   (Git Bash / macOS / Linux)
#   copy .env.example .env   (Windows CMD)

# Backend NestJS (local) o Fly en producción
NEXT_PUBLIC_API_URL=http://localhost:4000
# Vercel (cliente + build): https://gigasystem-api-cl.fly.dev
# Vercel (solo servidor, opcional, sin redeploy al cambiar):
# API_URL=https://gigasystem-api-cl.fly.dev

# URL pública del front (SEO, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
