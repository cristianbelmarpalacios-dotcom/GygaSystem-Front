# Copia este archivo a .env y ajusta si cambias puertos o dominio.
#   cp .env.example .env   (Git Bash / macOS / Linux)
#   copy .env.example .env   (Windows CMD)

# Backend NestJS (mismo puerto que PORT en GigaSystem-backend/.env)
NEXT_PUBLIC_API_URL=http://localhost:4000

# URL pública del front (SEO, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
